APP_ENV=local
APP_PORT=8080
FRONTEND_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# Database driver: mysql | sqlite
DB_DRIVER=sqlite
GORM_LOG_LEVEL=error
GORM_SLOW_THRESHOLD_MS=200

# MySQL (used when DB_DRIVER=mysql)
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=
MYSQL_PASSWORD=
MYSQL_DB=
MYSQL_CHARSET=utf8mb4
MYSQL_PARSE_TIME=true
MYSQL_LOC=Local
MYSQL_DSN=
FEIGE_CALL_RECORDING_COOKIE=
MIHUA_CALL_RECORD_LIST_URL=
MIHUA_TELEMARKETING_RECORDING_LIST_URL=
MIHUA_TELEMARKETING_RECORDING_DETAIL_URL=
MIHUA_CALL_RECORD_TOKEN=
MIHUA_CALL_RECORD_SOURCE_ORIGIN=

# SQLite fallback (used when DB_DRIVER=sqlite)
DB_PATH=data.db
JWT_SECRET=change-me-in-production
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_HOURS=168
SCHEDULE_TIMEZONE=Asia/Shanghai
HANGHANG_CRM_CLOUD_TOKEN=
BAIDU_MAP_AK=
BAIDU_MAP_BASE_URL=https://api.map.baidu.com

# Alibaba Cloud OSS Configuration (required)
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_BASE_PATH=avatars/

# External Company Search Configuration
ALIBABA_SEARCH_BASE_URL=https://www.alibaba.com/search/api/supplierTextSearch
MADE_IN_CHINA_BASE_URL=https://www.made-in-china.com
GOOGLE_API_KEY=
GOOGLE_CX=
GOOGLE_SEARCH_NUM=10
# Optional: set when the server needs a proxy to reach Google APIs, e.g. http://127.0.0.1:7890
GOOGLE_PROXY_URL=
EXTERNAL_COMPANY_SEARCH_WORKER_COUNT=2
EXTERNAL_COMPANY_SEARCH_POLL_INTERVAL_MS=1000
