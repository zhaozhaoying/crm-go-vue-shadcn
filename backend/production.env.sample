APP_ENV=production
APP_PORT=8080

# 前端线上域名。若前后端同域名并由 Nginx 反代 /api，这里填站点域名即可。
FRONTEND_ORIGIN=https://crm.example.com

# 线上走 Nginx 反代时，用于识别真实客户端 IP。
# 如果 Nginx 和 Go 在同一台机器，通常保留 127.0.0.1,::1 即可。
# 如果走 Docker 或内网代理，请补充对应网段，例如 172.17.0.0/16。
TRUSTED_PROXIES=127.0.0.1,::1

DB_DRIVER=mysql
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=crm_user
MYSQL_PASSWORD=change-me
MYSQL_DB=crm
MYSQL_CHARSET=utf8mb4
MYSQL_PARSE_TIME=true
MYSQL_LOC=Local
FEIGE_CALL_RECORDING_COOKIE=

JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRY_HOURS=24
REFRESH_TOKEN_EXPIRY_HOURS=168
SCHEDULE_TIMEZONE=Asia/Shanghai

GORM_LOG_LEVEL=error
GORM_SLOW_THRESHOLD_MS=200

# 资源池百度地图配置
BAIDU_MAP_AK=
BAIDU_MAP_BASE_URL=https://api.map.baidu.com

# 客户拜访地址解析兜底配置
# 现在前端会优先把省/市/区/详细地址直接传给后端；
# 这里只作为前端未传地址时的后备解析。
REVERSE_GEOCODE_BASE_URL=https://nominatim.openstreetmap.org
REVERSE_GEOCODE_USER_AGENT=crm-go-vue-shadcn/1.0

OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET_NAME=
OSS_BASE_PATH=avatars/

HANGHANG_CRM_CLOUD_TOKEN=

GOOGLE_API_KEY=
GOOGLE_CX=
GOOGLE_SEARCH_NUM=10
GOOGLE_PROXY_URL=

ALIBABA_SEARCH_BASE_URL=https://www.alibaba.com/search/api/supplierTextSearch
MADE_IN_CHINA_BASE_URL=https://www.made-in-china.com
MADE_IN_CHINA_PROXY_URL=

EXTERNAL_COMPANY_SEARCH_WORKER_COUNT=2
EXTERNAL_COMPANY_SEARCH_POLL_INTERVAL_MS=1000
